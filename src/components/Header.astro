---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "@/i18n/utils";
import ThemeToggle from "./ThemeToggle.astro";
import LanguagePicker from "./LanguagePicker.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = [
  { label: t("nav.blog"), path: "blog" },
  { label: t("nav.about"), path: "about" },
  { label: t("nav.ai"), path: "ai" },
  { label: t("nav.uses"), path: "uses" },
];

const normalizePath = (path: string) => path.replace(/\/$/, "") || "/";
const currentPath = normalizePath(Astro.url.pathname);
---

<header class="w-full max-w-3xl mx-auto px-6 pt-6 sm:pt-8 pb-4">
  <nav class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between" aria-label="Main navigation">
    <a
      href={getLocalizedPath(lang)}
      class="inline-flex min-h-11 items-center self-start rounded-md font-[var(--font-mono)] text-base tracking-tight text-[var(--color-ink)] dark:text-[var(--color-ink-dark)] no-underline hover:text-[var(--color-accent)] dark:hover:text-[var(--color-accent-dark)]"
    >
      <span class="font-semibold">marcomachado</span><span class="font-medium text-[var(--color-ink-muted)] dark:text-[var(--color-ink-muted-dark)]">.dev</span>
    </a>

    <div class="flex flex-wrap items-center gap-x-3 gap-y-2 sm:justify-end">
      {
        navLinks.map((link) => {
          const href = getLocalizedPath(lang, link.path);
          const isActive = currentPath === normalizePath(href);

          return (
            <a
              href={href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "inline-flex min-h-11 items-center rounded-md px-1 text-sm no-underline transition-colors",
                isActive
                  ? "font-medium text-[var(--color-ink)] dark:text-[var(--color-ink-dark)]"
                  : "text-[var(--color-ink-secondary)] hover:text-[var(--color-ink)] dark:text-[var(--color-ink-secondary-dark)] dark:hover:text-[var(--color-ink-dark)]",
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
      <span aria-hidden="true" class="hidden text-[var(--color-rule)] dark:text-[var(--color-rule-dark)] sm:inline">|</span>
      <LanguagePicker />
      <ThemeToggle />
    </div>
  </nav>
</header>
