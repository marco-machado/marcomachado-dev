---
import SectionLabel from "@/components/SectionLabel.astro";

interface Props {
  title?: string;
  num?: string;
}

const { title, num = "" } = Astro.props;
---

<section class="page-section">
  {title && <SectionLabel num={num}>{title}</SectionLabel>}
  <div class:list={[{ "page-section__body": title }]}>
    <slot />
  </div>
</section>
