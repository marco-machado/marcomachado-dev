---
import type { Lang } from "@/i18n/ui";
import { formatDate, getLocalizedPath } from "@/i18n/utils";

interface Props {
  idx: number;
  slug: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  lang: Lang;
}

const { idx, slug, title, description, date, tags, lang } = Astro.props;
const dateStr = formatDate(date, lang).toUpperCase();
const href = getLocalizedPath(lang, `blog/${slug}`);
---

<a class="post-row" href={href} style="text-decoration:none;color:inherit">
  <span class="num">{String(idx + 1).padStart(2, "0")} //</span>
  <div>
    <div class="title">{title}</div>
    <div class="subhead" style="margin-top:8px;max-width:62ch">{description}</div>
  </div>
  <div class="tags">
    {tags.map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <div class="date">{dateStr}</div>
</a>
