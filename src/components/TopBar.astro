---
import type { Lang } from "@/i18n/ui";
import { useTranslations, getOtherLang, getLocalizedPath } from "@/i18n/utils";

interface Props {
  lang: Lang;
  location: string;        // page label, e.g. "HOME"
  currentPath?: string;    // for lang-switch link target
}

const { lang, location, currentPath = "" } = Astro.props;
const t = useTranslations(lang);
const today = new Date()
  .toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" })
  .toUpperCase();
const otherLang = getOtherLang(lang);
const langHref = getLocalizedPath(otherLang, currentPath);
---

<div class="topbar">
  <div class="brand">
    <div class="brand-mark">M</div>
    <span class="brand-name">marcomachado.dev</span>
  </div>

  <div class="center">
    <span class="crumb">[ Index ]</span>
    <span class="crumb active">/ {location} _</span>
  </div>

  <div class="meta">
    <span class="hide-on-narrow">{today}</span>
    <span class="hide-on-narrow">v26.04</span>
    <a class="lang-toggle" href={langHref} title="Switch language">
      {lang === "en" ? "EN ⇄ PT" : "PT ⇄ EN"}
    </a>
    <span style="display:flex;align-items:center;gap:8px"><span class="dot"></span> ONLINE</span>
  </div>
</div>
