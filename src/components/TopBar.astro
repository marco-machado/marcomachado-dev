---
import type { Lang } from "@/i18n/ui";
import { useTranslations, getOtherLang, getLocalizedPath } from "@/i18n/utils";

interface Props {
  lang: Lang;
  current: "home" | "blog" | "about" | "uses" | "ai";
  currentPath?: string;
}

const { lang, current, currentPath = "" } = Astro.props;
const t = useTranslations(lang);
const otherLang = getOtherLang(lang);
const langHref = getLocalizedPath(otherLang, currentPath);

const items = [
  { id: "home", label: t("nav.home"), href: getLocalizedPath(lang, "") },
  { id: "blog", label: t("nav.blog"), href: getLocalizedPath(lang, "blog") },
  { id: "about", label: t("nav.about"), href: getLocalizedPath(lang, "about") },
  { id: "uses", label: t("nav.uses"), href: getLocalizedPath(lang, "stack") },
  { id: "ai", label: t("nav.ai"), href: getLocalizedPath(lang, "ai") },
] as const;
---

<header class="topbar">
  <a class="brand" href={getLocalizedPath(lang, "")} aria-label={t("site.title")}>
    <div class="brand-mark">M</div>
    <span class="brand-name">marcomachado.dev</span>
  </a>

  <nav class="topbar-nav" aria-label="Primary navigation">
    {items.map((it, i) => (
      <a
        class:list={["topbar-nav-item", { active: current === it.id }]}
        href={it.href}
      >
        <span class="nav-num">0{i + 1}</span>
        {it.label}
      </a>
    ))}
  </nav>

  <div class="meta">
    <span class="hide-on-narrow">v26.04</span>
    <a class="lang-toggle" href={langHref} title={t("topbar.switchLanguage")}>
      {lang === "en" ? "EN ⇄ PT" : "PT ⇄ EN"}
    </a>
    <span style="display:flex;align-items:center;gap:8px"><span class="dot"></span> {t("topbar.online")}</span>
  </div>
</header>
