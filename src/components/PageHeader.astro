---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="page-header">
  <div>
    <div class="eyebrow">{eyebrow}</div>
    <h1 class="display page-header__title">{title}</h1>
  </div>
  <p class="subhead page-header__description">{description}</p>
</header>
