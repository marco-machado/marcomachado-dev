---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Newsletter from "@/components/Newsletter.astro";
import type { Lang } from "@/i18n/ui";
import { useTranslations, formatDate, getLocalizedPath } from "@/i18n/utils";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  slug: string;
}

const { lang, title, description, pubDate, updatedDate, tags, slug } = Astro.props;
const t = useTranslations(lang);
const backHref = getLocalizedPath(lang, "blog");
---

<BaseLayout
  lang={lang}
  current="blog"
  location="POSTS"
  title={`${title} — ${t("site.title")}`}
  description={description}
  currentPath={`blog/${slug}`}
>
  <article class="page article" style="padding-top:40px">
    <a
      href={backHref}
      style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-muted-ash);display:inline-block;margin-bottom:36px"
    >
      ← {t("post.back")}
    </a>

    <h1 class="article-title">{title}</h1>
    <p class="subhead" style="margin-bottom:24px">{description}</p>

    <div class="article-meta">
      <span><span class="accent">{t("post.published")}</span> · {formatDate(pubDate, lang)}</span>
      {updatedDate && (
        <span><span class="accent">{t("post.updated")}</span> · {formatDate(updatedDate, lang)}</span>
      )}
      <span><span class="accent">{t("post.tags")}</span> · {tags.join(" · ")}</span>
    </div>

    <div class="article-content">
      <slot />
    </div>

    <div style="margin-top:80px">
      <Newsletter lang={lang} />
    </div>
  </article>
</BaseLayout>
