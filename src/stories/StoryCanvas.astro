---
interface Props {
  padded?: boolean;
  width?: "page" | "narrow" | "full";
}

const { padded = true, width = "page" } = Astro.props;
const maxWidth = width === "narrow" ? "760px" : width === "page" ? "1200px" : "none";
---

<div style={`background:#000;color:#fff;min-height:100vh;${padded ? "padding:32px;" : ""}`}>
  <div style={`max-width:${maxWidth};margin:0 auto;`}>
    <slot />
  </div>
</div>
