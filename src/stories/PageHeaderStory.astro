---
import StoryCanvas from "./StoryCanvas.astro";
import PageHeader from "@/components/PageHeader.astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<StoryCanvas>
  <PageHeader eyebrow={eyebrow} title={title} description={description} />
</StoryCanvas>
