---
import StoryCanvas from "./StoryCanvas.astro";
import PageSectionDemo from "./PageSectionDemo.astro";

interface Props {
  title: string;
  num: string;
  spacing?: "default" | "large";
}

const { title, num, spacing = "default" } = Astro.props;
---

<StoryCanvas>
  <PageSectionDemo title={title} num={num} spacing={spacing} />
</StoryCanvas>
