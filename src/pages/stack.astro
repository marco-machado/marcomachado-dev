---
import PageShell from "@/components/PageShell.astro";
import PageHeader from "@/components/PageHeader.astro";
import KvSection from "@/components/KvSection.astro";
import { useTranslations } from "@/i18n/utils";
import { uses } from "@/data/site";
import type { Lang } from "@/i18n/ui";

interface Props { lang?: Lang; }
const { lang = "en" }: Props = Astro.props;
const t = useTranslations(lang);
const sections = uses[lang];
---

<PageShell
  lang={lang}
  current="uses"
  location="STACK"
  title={`${t("uses.heading")} — ${t("site.title")}`}
  description={t("uses.intro")}
  currentPath="stack"
>
    <PageHeader
      eyebrow={t("uses.eyebrow")}
      title={t("uses.heading")}
      description={t("uses.intro")}
    />

    {sections.map((s, i) => (
      <KvSection
        num={String(i + 1).padStart(2, "0")}
        title={t(s.titleKey as any)}
        rows={s.rows}
      />
    ))}
</PageShell>
