---
import PageShell from "@/components/PageShell.astro";
import PageSection from "@/components/PageSection.astro";
import OutlinedButton from "@/components/OutlinedButton.astro";
import PostRow from "@/components/PostRow.astro";
import { getCollection } from "astro:content";
import { useTranslations, getLocalizedPath } from "@/i18n/utils";
import type { Lang } from "@/i18n/ui";

interface Props { lang?: Lang; }
const { lang = "en" }: Props = Astro.props;
const t = useTranslations(lang);

const posts = (await getCollection("blog"))
  .filter((p) => p.data.lang === lang && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageShell lang={lang} current="home" location={t("location.home")} currentPath="">
    <div style="padding:60px 0 40px">
      <div class="eyebrow">{t("home.eyebrow")}</div>
      <h1 class="display">
        {t("home.greeting.line1")}<br />
        {t("home.greeting.line2")}<br />
        {t("home.greeting.line3")}<span class="cursor"></span>
      </h1>
      <p class="subhead" style="margin-top:36px;max-width:60ch">{t("home.intro")}</p>

      <div style="display:flex;gap:14px;margin-top:56px;flex-wrap:wrap">
        <OutlinedButton
          label={t("home.cta.blog.label")}
          sub={t("home.cta.blog.sub")}
          href={getLocalizedPath(lang, "blog")}
        />
        <OutlinedButton
          label={t("home.cta.about.label")}
          sub={t("home.cta.about.sub")}
          href={getLocalizedPath(lang, "about")}
        />
        <OutlinedButton
          label={t("home.cta.work.label")}
          sub={t("home.cta.work.sub")}
          href={getLocalizedPath(lang, "stack")}
        />
      </div>
    </div>

    <PageSection title={t("home.latestPosts")} num="01">
        {posts.slice(0, 3).map((p, i) => {
          const slug = p.id.split("/")[1];
          return (
            <PostRow
              idx={i}
              slug={slug}
              title={p.data.title}
              description={p.data.description}
              date={p.data.pubDate}
              tags={p.data.tags}
              lang={lang}
            />
          );
        })}
      <div style="display:flex;justify-content:flex-end;margin-top:32px">
        <a
          href={getLocalizedPath(lang, "blog")}
          style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-accent)"
        >
          → {t("home.viewAll")}
        </a>
      </div>
    </PageSection>
</PageShell>
