---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionLabel from "@/components/SectionLabel.astro";
import PostRow from "@/components/PostRow.astro";
import Newsletter from "@/components/Newsletter.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "@/i18n/utils";
import type { Lang } from "@/i18n/ui";

interface Props { lang?: Lang; }
const { lang = "en" }: Props = Astro.props;
const t = useTranslations(lang);

const posts = (await getCollection("blog"))
  .filter((p) => p.data.lang === lang && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  lang={lang}
  current="blog"
  location="WRITING"
  title={`${t("blog.heading")} — ${t("site.title")}`}
  description={t("blog.description")}
  currentPath="blog"
>
  <div class="page" style="padding-top:40px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;padding-bottom:56px">
      <div>
        <div class="eyebrow">/ writing log</div>
        <h1 class="display" style="font-size:clamp(56px,8vw,110px)">{t("blog.heading")}</h1>
      </div>
      <p class="subhead" style="padding-bottom:12px">{t("blog.description")}</p>
    </div>

    {posts.length === 0 ? (
      <p class="subhead">{t("blog.empty")}</p>
    ) : (
      <>
        <SectionLabel num={`/ ${posts.length} entries`}>archive</SectionLabel>
        <div style="margin-top:24px">
          {posts.map((p, i) => {
            const slug = p.id.split("/")[1];
            return (
              <PostRow
                idx={i}
                slug={slug}
                title={p.data.title}
                description={p.data.description}
                date={p.data.pubDate}
                tags={p.data.tags}
                lang={lang}
              />
            );
          })}
        </div>
      </>
    )}

    <div style="margin-top:100px">
      <Newsletter lang={lang} />
    </div>
  </div>
</BaseLayout>
