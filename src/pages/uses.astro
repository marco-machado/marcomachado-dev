---
import BaseLayout from "@/layouts/BaseLayout.astro";
import KvSection from "@/components/KvSection.astro";
import { useTranslations } from "@/i18n/utils";
import { uses } from "@/data/site";
import type { Lang } from "@/i18n/ui";

interface Props { lang?: Lang; }
const { lang = "en" }: Props = Astro.props;
const t = useTranslations(lang);
const sections = uses[lang];
---

<BaseLayout
  lang={lang}
  current="uses"
  location="STACK"
  title={`${t("uses.heading")} — ${t("site.title")}`}
  description={t("uses.intro")}
  currentPath="uses"
>
  <div class="page" style="padding-top:40px">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;padding-bottom:24px">
      <div>
        <div class="eyebrow">/ daily kit</div>
        <h1 class="display" style="font-size:clamp(56px,8vw,110px)">{t("uses.heading")}</h1>
      </div>
      <p class="subhead" style="padding-bottom:12px">{t("uses.intro")}</p>
    </div>

    {sections.map((s, i) => (
      <KvSection
        num={String(i + 1).padStart(2, "0")}
        title={t(s.titleKey as any)}
        rows={s.rows}
      />
    ))}
  </div>
</BaseLayout>
